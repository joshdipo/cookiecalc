@page "/cookiecalc"
@using System.Text.RegularExpressions
@using cookiecalc.MyMCookie
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Sections

<PageTitle>Cookie Calc</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">
    <MudStack Spacing="4">
        <div>
            <h1>Recipe Creator</h1>
            <p class="text-muted">Use this to create and store different recipes!</p>
        </div>
        <SectionOutlet SectionName="debug" />
        <SectionOutlet SectionName="tabs" />
    </MudStack>
</MudContainer>




<!-- Debug -->
<SectionContent SectionName="debug">
    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Elevation="4">
        <strong>DEBUG:</strong> @debugMessage
    </MudAlert>
</SectionContent>
@code{
    private string debugMessage = "";
}

<!-- Tabs -->
<SectionContent SectionName="tabs">
    <MudTabs Outlined="true" Elevation="0" Rounded="true" Border="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6">
        <MudTabPanel Text="Ingredients" Icon="@Icons.Material.Rounded.List">
            <SectionOutlet SectionName="ingredients-tab" />
        </MudTabPanel>
        <MudTabPanel Text="Recipes" Icon="@Icons.Material.Rounded.MenuBook">
            <SectionOutlet SectionName="recipes-tab" />
        </MudTabPanel>
    </MudTabs>
</SectionContent>


<!-- Ingredients Panel -->
<SectionContent SectionName="ingredients-tab">
    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="4">
            <div>
                <h3>Add Ingredient</h3>
                <p class="text-muted">Select an ingredient, amount, and unit to add to your recipe.</p>
            </div>
            <!-- Add ingredient form will go here -->
            <MudGrid Spacing="1" Class="align-center">
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Immediate="true" @bind-Value="textBoxName" Mask="@maskString" Label="Name" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Immediate="true" @bind-Value="textBoxCategory" Mask="@maskString" Label="Category" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Immediate="true" @bind-Value="textBoxDensity" Mask="@maskDouble" Label="Density" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentText="grams"></MudTextField>
                </MudItem>
                <MudItem xs="12" sm="12" md="3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" OnClick="ButtonAddIngredient">Add</MudButton>
                </MudItem>
                @if (!string.IsNullOrEmpty(textIngredientsListMessage))
                {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@textIngredientsListMessage</MudAlert>
                </MudItem>
                }
            </MudGrid>
            <!-- Ingredient list -->
            <MudTable Items="@Ingredients.IngredientList.Values"  Hover="true" Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" SortLabel="Sort By">
                <ColGroup>
                    <col style="width: 30%;" />
                    <col style="width: 30%;" />
                    <col style="width: 25%;" />
                    <col style="width: 15%;" />
                </ColGroup>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<Ingredient, object>(x=>x.Name)">Name</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<Ingredient, object>(x=>x.Category)">Category</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<Ingredient, object>(x=>x.Density)">Density (grams per ml)</MudTableSortLabel></MudTh>
                    <MudTh Class="d-flex justify-center">Remove</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Category">@context.Category</MudTd>
                    <MudTd DataLabel="Density">@context.Density</MudTd>
                    <MudTd DataLabel="Remove" Class="d-flex justify-center"><MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Variant="Variant.Filled" aria-label="delete" @onclick="@(e => ButtonRemoveIngredient(context.Name))" /></MudTd>
                </RowTemplate>
            </MudTable>
        </MudStack>
    </MudPaper>
</SectionContent>
@code {
    public string textBoxName { get; set; } = "";
    public string textBoxCategory { get; set; } = "";
    public double textBoxDensity { get; set; }
    private string textIngredientsListMessage = "";

    public IMask maskString = new RegexMask(@"^[\w\s]+$");
    public IMask maskDouble = new RegexMask(@"^[\d\.]+$");

    // Add Ingredient Button
    public void ButtonAddIngredient()
    {
        try{
            Ingredients.SetIngredient(
                name:textBoxName,
                category:textBoxCategory,
                density:textBoxDensity
            );
            debugMessage = $"Ingredients list has {Ingredients.IngredientList.Count} items";
            textIngredientsListMessage = "";
        }
        catch (Exception e){
            textIngredientsListMessage = $"Cannot add ingredient to list: {e.Message}";
        }
    }

    // Remove Ingredient Button
    public void ButtonRemoveIngredient(string name)
    {
        try{
            Ingredients.RemoveIngredient(name);
            debugMessage = $"Ingredients list has {Ingredients.IngredientList.Count} items";
            textIngredientsListMessage = "";
        }
        catch (Exception e){
            textIngredientsListMessage = $"Cannot remove ingredient from list: {e.Message}";
        }
    }

    // Check if any recipe contains an ingredient
    public bool IngredientInUse(string name){
        return true;
    }
}


<!-- Recipe Panel -->
<SectionContent SectionName="recipes-tab">
    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="4">
            <div>
                <h3>Your Recipes</h3>
                <p class="text-muted">View and manage your saved recipes.</p>
            </div>
            <!-- Recipe list will go here -->
        </MudStack>
    </MudPaper>
</SectionContent>
@code{
    // Recipe basics vars
    string textBoxRecipeName = "";
    string textBoxRecipeDescription ="";

    // Recipe ingredient vars
    object dropDownUnit = MetricWeightUnit.Gram;
}